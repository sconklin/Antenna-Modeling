def inches(meters):
    return float(meters* 39.3700787)

def mm2m(length):
    return (length/1000)

# convert to sci and also mm to meters, adjust to fixed field width
def tosci(num, fieldlength=13):
    result = "%.5E" % num
    while (len(result) < fieldlength):
        result = " " + result
    return result

def toint(val, fieldlength):
    result = "%d" % val
    while (len(result) < fieldlength):
        result = " " + result
    return result

